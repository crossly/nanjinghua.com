{
	"name": "nanjinghua.com",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.32.0",
	"engines": {
		"node": "24.18.0"
	},
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "vite dev --port 3000",
		"generate-routes": "tsr generate",
		"build": "pnpm run validate:content && vite build",
		"validate:content": "node scripts/validate-content.ts",
		"preview": "vite preview --port 4173",
		"preview:worker": "pnpm run build && wrangler dev --port 4173",
		"typecheck": "tsc --noEmit",
		"test": "pnpm run test:unit && pnpm run test:e2e",
		"test:unit": "node --test tests/content-schema.test.ts",
		"test:e2e": "playwright test",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check .",
		"deploy": "pnpm run build && wrangler deploy"
	},
	"dependencies": {
		"@cloudflare/vite-plugin": "1.45.0",
		"@tanstack/react-router": "1.170.18",
		"@tanstack/react-start": "1.168.28",
		"lucide-react": "0.545.0",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-markdown": "10.1.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@playwright/test": "1.61.1",
		"@tanstack/router-cli": "1.167.19",
		"@types/node": "24.13.3",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.3",
		"typescript": "6.0.3",
		"vite": "8.1.5",
		"wrangler": "4.111.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"lightningcss"
		]
	}
}
